{
    "compilerOptions": {
        "allowJs": false,
        "target": "ESNext",
        "module": "CommonJS",
        "esModuleInterop": true,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "types": [
            "node",
            "express"
        ]
    },
    "include": [
        "src/**/*.ts",
        "scripts/**/*.ts"
    ]
}